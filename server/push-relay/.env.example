# Fetch push relay — production environment template.
# Copy to your host's secret manager / fly secrets; never commit real values.

# ── APNs provider credentials (the ONE Fetch key — lives ONLY here) ──
# Prefer the inline PEM via a secret manager:
HERMES_RELAY_APNS_KEY="<apns-p8-private-key-pem-with-newlines-escaped>"
# ...or point at a mounted .p8 file instead of the inline key:
# HERMES_RELAY_APNS_KEY_PATH=/secrets/AuthKey_XXXXXXXXXX.p8
HERMES_RELAY_APNS_KEY_ID=XXXXXXXXXX
HERMES_RELAY_APNS_TEAM_ID=XXXXXXXXXX

# ── Enrollment / abuse control ──
# Required in production: agents must present this to register (relay fails
# closed if neither this nor ALLOW_OPEN_REGISTRATION is set).
HERMES_RELAY_REGISTRATION_TOKEN=replace-with-long-random
# Local dev only — allow anonymous agent registration without a token:
# HERMES_RELAY_ALLOW_OPEN_REGISTRATION=true
HERMES_RELAY_RATE_LIMIT_PER_MIN=120
HERMES_RELAY_MAX_DEVICES_PER_AGENT=50

# ── Topic / privacy ──
# App IDs the key is authorized for (comma-separated). Stale/other bundle ids
# are rejected at registration so they can't silently fail forever.
HERMES_RELAY_ALLOWED_BUNDLE_IDS=com.brentwarner.fetch
# Send title/body text provided by the Fetch plugin through APNs. Set to false
# to force generic lock-screen copy when conversation text must stay off the relay.
HERMES_RELAY_ALLOW_CUSTOM_BODY=true

# ── App-to-agent reverse tunnel ──
# Required for relay pairing and remote Fetch app streaming.
HERMES_RELAY_ENABLE_TUNNEL=true

# ── Storage / hardening ──
# Persistent path (mount a volume here). Postgres recommended at scale.
HERMES_RELAY_DATABASE_PATH=/data/push-relay.db
# Pepper for HMAC agent-secret hashing (stable across restarts or auth breaks).
HERMES_RELAY_SECRET_PEPPER=replace-with-long-random
